\pard\plain \fi720\qj\hyphpar1\sb0\sa0 \f4\fs24 \fi698\qr {\*\bkmkstart sub_50000}\cs65552\f4\fs24 {\cs26\b1\cf17 \b1\cf17 Приложение №\~5\line к {\field{\*\fldinst {HYPERLINK \\l "sub_1000"}}{\fldrslt {\cs24\b0\cf18 Программе}}} государственных гарантий\line бесплатного оказания гражданам\line медицинской помощи на 2026\~год\line и на плановый период 2027 и 2028\~годов}\par\pard
